# Database
# Use a PostgreSQL URL for production (e.g. Supabase)
DATABASE_URL="postgres://user:password@host:port/dbname"

# Local SQLite (auto-created if no DATABASE_URL is provided)
# SQLITE_DB_PATH="./splitmint.db"

# Authentication
JWT_SECRET="your-super-secret-jwt-key"

# AI Integration (MintSense)
# This app uses Groq for fast inference
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Optional: Anthropic (if you switch back to Claude)
# ANTHROPIC_API_KEY="sk-ant-..."

# Next.js Settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
